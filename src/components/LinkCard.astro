---
interface Props {
  href: string
  icono: string
  titulo: string
  descripcion?: string
  external?: boolean
}
const { href, icono, titulo, descripcion, external = true } = Astro.props

const isBooking = href.includes('booking.com')
const isAirbnb  = href.includes('airbnb.com')
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class={`link-card group flex items-center gap-4 w-full rounded-2xl px-5 py-4 no-underline ${isBooking ? 'booking-card' : isAirbnb ? 'airbnb-card' : 'brand-card'}`}
>
  <!-- Platform logo or emoji -->
  <div class="icon-wrap w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 bg-white bg-opacity-20">
    {isBooking ? (
      <!-- Booking.com logo mark -->
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect width="28" height="28" rx="6" fill="white" fill-opacity="0.2"/>
        <text x="14" y="20" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="900" fill="white">B.</text>
      </svg>
    ) : isAirbnb ? (
      <!-- Airbnb logo mark -->
      <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <path d="M12 2C9.5 2 7.5 4.2 6.2 7.2C5.2 9.5 4.5 11.5 4.5 13.2c0 2.6 1.7 4.8 3.8 4.8 1.2 0 2.2-.6 3-1.5.4-.4.6-.7.7-.9.1.2.3.5.7.9.8.9 1.8 1.5 3 1.5 2.1 0 3.8-2.2 3.8-4.8 0-1.7-.7-3.7-1.7-6C17.5 4.2 15.5 2 13 2h-1z"/>
      </svg>
    ) : (
      <span class="text-xl" aria-hidden="true">{icono}</span>
    )}
  </div>

  <!-- Text -->
  <div class="min-w-0 flex-1">
    <p class="font-semibold text-[0.9375rem] leading-tight text-white">{titulo}</p>
    {descripcion && (
      <p class="text-xs mt-0.5 text-white opacity-75 truncate">{descripcion}</p>
    )}
  </div>

  <!-- External arrow -->
  <div class="flex-shrink-0 transition-transform duration-200 group-hover:translate-x-1">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M7 4H4a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-3M10 4h4m0 0v4m0-4L8 12"
        stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.8"/>
    </svg>
  </div>
</a>

<style>
  .link-card {
    min-height: 72px;
    transition: box-shadow 200ms ease-out, transform 200ms ease-out;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .link-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.2);
    transform: translateY(-2px);
  }

  .link-card:active {
    transform: scale(0.99);
    transition-duration: 80ms;
  }

  .booking-card { background: #003b95; }
  .airbnb-card  { background: #FF385C; }
  .brand-card   { background: var(--brand-primary); }

  @media (prefers-reduced-motion: reduce) {
    .link-card { transition: none; }
    .link-card:hover { transform: none; }
  }
</style>
