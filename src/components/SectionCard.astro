---
interface Props {
  href: string
  icono: string
  titulo: string
  descripcion?: string
  delay?: number
}
const { href, icono, titulo, descripcion, delay = 0 } = Astro.props
---

<a
  href={href}
  class="section-card group flex items-center gap-4 w-full rounded-2xl bg-white px-5 py-4 no-underline"
  style={delay ? `animation-delay: ${delay}ms` : ''}
>
  <!-- Icon badge -->
  <div
    class="icon-badge w-12 h-12 rounded-xl flex items-center justify-center text-xl flex-shrink-0 transition-transform duration-200"
    style="background: color-mix(in srgb, var(--brand-primary) 10%, transparent);"
    aria-hidden="true"
  >
    {icono}
  </div>

  <!-- Text -->
  <div class="min-w-0 flex-1">
    <p class="font-semibold text-[0.9375rem] leading-tight" style="color: var(--brand-primary)">
      {titulo}
    </p>
    {descripcion && (
      <p class="text-xs mt-0.5 leading-relaxed truncate" style="color: var(--brand-primary); opacity: 0.5">
        {descripcion}
      </p>
    )}
  </div>

  <!-- Arrow -->
  <div class="flex-shrink-0 arrow-icon transition-transform duration-200">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M6.75 13.5L11.25 9L6.75 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
        style="color: var(--brand-accent)"/>
    </svg>
  </div>
</a>

<style>
  .section-card {
    border: 1px solid color-mix(in srgb, var(--brand-primary) 8%, transparent);
    border-left: 3px solid transparent;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    transition: box-shadow 200ms ease-out, transform 200ms ease-out, border-color 200ms ease-out;
    animation: fadeUp 0.35s ease-out both;
  }

  .section-card:hover {
    border-left-color: var(--brand-accent);
    box-shadow: 0 6px 24px rgba(0,0,0,0.09);
    transform: translateY(-2px);
  }

  .section-card:active {
    transform: translateY(0px) scale(0.99);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition-duration: 80ms;
  }

  .section-card:hover .icon-badge {
    transform: scale(1.05);
    background: color-mix(in srgb, var(--brand-accent) 15%, transparent) !important;
  }

  .section-card:hover .arrow-icon {
    transform: translateX(3px);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-card { animation: none; transition: none; }
    .section-card:hover { transform: none; }
  }
</style>
