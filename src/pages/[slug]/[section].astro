---
import PropertyLayout from '../../layouts/PropertyLayout.astro'
import LinkCard from '../../components/LinkCard.astro'
import { supabase } from '../../lib/supabase'
import type { Client, Section, Link } from '../../lib/types'
import { marked } from 'marked'

const { slug, section: sectionSlug } = Astro.params

const { data: client } = await supabase
  .from('clients')
  .select('*')
  .eq('slug', slug)
  .eq('activo', true)
  .single<Client>()

if (!client) return Astro.redirect('/', 302)

const { data: section } = await supabase
  .from('sections')
  .select('*')
  .eq('client_id', client.id)
  .eq('slug', sectionSlug)
  .eq('activo', true)
  .single<Section>()

if (!section) return Astro.redirect(`/${slug}`, 302)

const { data: links } = await supabase
  .from('links')
  .select('*')
  .eq('section_id', section.id)
  .eq('activo', true)
  .order('orden', { ascending: true })

const sectionLinks = (links ?? []) as Link[]
const htmlContent = section.contenido ? marked(section.contenido) : ''
---

<PropertyLayout client={client} title={section.titulo}>

  <!-- Contenido principal (estrecho) -->
  <div class="max-w-md mx-auto px-4 pt-8 pb-6">

    <!-- Back navigation -->
    <a href={`/${slug}`} class="back-link">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {client.nombre}
    </a>

    <!-- Section header -->
    <header class="section-header animate-fade-up">
      <div class="icon-display" aria-hidden="true">{section.icono}</div>
      <h1 class="section-title">{section.titulo}</h1>

      <div class="title-accent" aria-hidden="true">
        <div class="accent-line" />
        <svg width="8" height="8" viewBox="0 0 8 8" class="accent-diamond">
          <path d="M4 0L8 4L4 8L0 4Z" fill="currentColor"/>
        </svg>
        <div class="accent-line" />
      </div>

      {section.descripcion && (
        <p class="section-desc">{section.descripcion}</p>
      )}
    </header>

    <!-- Links (review-type sections) -->
    {sectionLinks.length > 0 && (
      <div class="links-section">
        {sectionLinks.length > 1 && (
          <p class="links-label">Déjanos tu opinión</p>
        )}
        <div class="flex flex-col gap-3">
          {sectionLinks.map((link, i) => (
            <div class="link-item" style={`animation-delay: ${i * 80}ms`}>
              <LinkCard
                href={link.url}
                icono={link.icono}
                titulo={link.titulo}
                descripcion={link.descripcion}
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Markdown content -->
    {htmlContent && (
      <div
        class={`prose max-w-none content-block ${sectionLinks.length > 0 ? 'has-links' : ''}`}
        set:html={htmlContent}
      />
    )}
  </div>

  <!-- PDF — fuera del contenedor estrecho, ancho completo -->
  {section.pdf_url && (
    <div class={`pdf-section ${htmlContent || sectionLinks.length > 0 ? 'has-content' : ''}`}>

      <!-- Botón siempre visible (especialmente útil en móvil) -->
      <div class="pdf-btn-wrap">
        <a href={section.pdf_url} target="_blank" rel="noopener noreferrer" class="pdf-btn">
          <svg width="22" height="22" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="flex-shrink-0">
            <path d="M11 2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M11 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7 13h6M7 10h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Abrir documento completo</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="flex-shrink-0 opacity-50">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Iframe embebido — solo desktop, oculto en móvil -->
      <div class="pdf-embed-wrap">
        <iframe
          src={`${section.pdf_url}#toolbar=1&view=FitH&zoom=page-width`}
          class="pdf-embed"
          title={`PDF: ${section.titulo}`}
          loading="lazy"
          allowfullscreen
        />
      </div>

      <!-- Aviso móvil -->
      <p class="pdf-mobile-hint">
        📄 Tu dispositivo no muestra el PDF aquí — usa el botón de arriba para abrirlo.
      </p>

    </div>
  )}

  <div class="pb-12"></div>
</PropertyLayout>

<style>
  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: 2rem;
    opacity: 0.45;
    color: var(--brand-primary);
    text-decoration: none;
    transition: opacity 180ms ease;
  }
  .back-link:hover { opacity: 0.75; }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--brand-primary) 10%, transparent);
  }

  .icon-display {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--brand-primary);
    margin: 0;
  }

  .title-accent {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 80px;
    margin: 0.9rem auto 0.85rem;
    color: var(--brand-accent);
  }
  .accent-line { flex: 1; height: 1px; background: currentColor; opacity: 0.6; }
  .accent-diamond { flex-shrink: 0; }

  .section-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--brand-primary);
    opacity: 0.6;
    font-style: italic;
    margin: 0;
  }

  /* Links section */
  .links-section { margin-bottom: 2rem; }

  .links-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--brand-accent);
    text-align: center;
    margin-bottom: 1rem;
  }

  .link-item {
    animation: fadeUp 0.35s ease-out both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Content prose overrides */
  .content-block { color: var(--brand-primary); }
  .content-block.has-links {
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--brand-primary) 10%, transparent);
  }

  /* ── PDF ── */
  .pdf-section {
    width: 100%;
    padding: 0 16px 0;
  }
  .pdf-section.has-content {
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--brand-primary) 10%, transparent);
    margin-top: 0;
  }

  /* Botón */
  .pdf-btn-wrap {
    max-width: 600px;
    margin: 0 auto 1rem;
  }
  .pdf-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 16px 20px;
    background: white;
    border: 1.5px solid color-mix(in srgb, var(--brand-primary) 18%, transparent);
    border-radius: 16px;
    color: var(--brand-primary);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    transition: box-shadow 180ms ease, border-color 180ms ease, transform 180ms ease;
  }
  .pdf-btn:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.12);
    border-color: color-mix(in srgb, var(--brand-accent) 70%, transparent);
    transform: translateY(-1px);
  }
  .pdf-btn span { flex: 1; }

  /* iframe — visible solo en desktop */
  .pdf-embed-wrap {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--brand-primary) 12%, transparent);
    background: #f0f0f0;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .pdf-embed {
    width: 100%;
    height: calc(100vh - 200px);
    min-height: 500px;
    max-height: 900px;
    border: none;
    display: block;
  }

  /* Aviso móvil — oculto en desktop */
  .pdf-mobile-hint {
    display: none;
    text-align: center;
    font-size: 0.8rem;
    opacity: 0.5;
    margin-top: 0.5rem;
    color: var(--brand-primary);
  }

  /* En móvil: ocultar iframe, mostrar aviso */
  @media (max-width: 767px) {
    .pdf-embed-wrap { display: none; }
    .pdf-mobile-hint { display: block; }
    .pdf-btn { font-size: 1rem; padding: 18px 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .link-item { animation: none; }
  }
</style>
