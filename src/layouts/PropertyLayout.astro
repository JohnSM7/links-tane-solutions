---
import type { Client } from '../lib/types'

interface Props {
  client: Client
  title?: string
}

const { client, title } = Astro.props
const pageTitle = title ? `${title} · ${client.nombre}` : client.nombre
const brandVars = `
  --brand-primary: ${client.brand_primary};
  --brand-bg: ${client.brand_background};
  --brand-accent: ${client.brand_accent};
`
---

<!doctype html>
<html lang="es" style={brandVars}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={`Información y recursos de ${client.nombre}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      body {
        background-color: var(--brand-bg);
        color: var(--brand-primary);
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        min-height: 100dvh;
        /* Subtle linen dot texture */
        background-image: radial-gradient(circle, rgba(0,0,0,0.025) 1px, transparent 1px);
        background-size: 22px 22px;
      }

      .font-serif { font-family: 'Playfair Display', Georgia, serif; }

      /* Prose styles for markdown content */
      .prose { line-height: 1.75; font-size: 0.9375rem; }
      .prose h1 { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 600; margin: 0 0 1.25rem; line-height: 1.2; color: var(--brand-primary); }
      .prose h2 { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 600; margin: 2rem 0 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid; border-color: color-mix(in srgb, var(--brand-accent) 30%, transparent); color: var(--brand-primary); }
      .prose h3 { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--brand-primary); }
      .prose p { margin: 0 0 1rem; opacity: 0.8; }
      .prose ul { margin: 0 0 1rem; padding-left: 0; list-style: none; }
      .prose ul li { position: relative; padding-left: 1.5rem; margin-bottom: 0.5rem; opacity: 0.8; }
      .prose ul li::before { content: '—'; position: absolute; left: 0; color: var(--brand-accent); font-weight: 600; }
      .prose ol { margin: 0 0 1rem; padding-left: 1.5rem; }
      .prose ol li { margin-bottom: 0.5rem; opacity: 0.8; }
      .prose strong { font-weight: 600; opacity: 1; color: var(--brand-primary); }
      .prose em { font-style: italic; }
      .prose a { color: var(--brand-accent); text-decoration: underline; text-underline-offset: 3px; }
      .prose blockquote { border-left: 3px solid var(--brand-accent); padding-left: 1rem; margin: 1.5rem 0; font-style: italic; opacity: 0.7; }
      .prose hr { border: none; border-top: 1px solid; border-color: color-mix(in srgb, var(--brand-primary) 15%, transparent); margin: 2rem 0; }
      .prose code { background: color-mix(in srgb, var(--brand-primary) 8%, transparent); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.875em; }

      /* Smooth page transitions */
      @media (prefers-reduced-motion: no-preference) {
        .animate-fade-up {
          animation: fadeUp 0.4s ease-out both;
        }
        @keyframes fadeUp {
          from { opacity: 0; transform: translateY(12px); }
          to { opacity: 1; transform: translateY(0); }
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <footer class="text-center py-10 mt-8">
      <div class="inline-flex items-center gap-2 opacity-30 hover:opacity-50 transition-opacity duration-200">
        <span style="display:inline-block; width:1px; height:12px; background:currentColor;"></span>
        <a href="https://tanesolutions.com" target="_blank"
          class="text-[10px] uppercase tracking-[0.25em] font-medium no-underline">
          Tane Solutions
        </a>
        <span style="display:inline-block; width:1px; height:12px; background:currentColor;"></span>
      </div>
    </footer>
  </body>
</html>
